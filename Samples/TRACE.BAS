DATA 0061004799999999003100440028004500260045002500430025004100240042002300440024004600250047002800470031004599999999003200400031003800290036002700360024003800230039999999990061006500630068006500709999999900590077006000800061008299999999003000810029008400290086

DIM st$(6)

FOR i% = 1 TO 6
  READ st$(i%)
NEXT i%

SCREEN 12

FOR i% = 1 TO 6
  r% = RND * 255
  g% = RND * 255
  b% = RND * 255

  IF rr% < 96 AND gg% < 96 AND bb% < 96 THEN
    IF RND > .5 THEN r% = 255
    IF RND > .5 THEN g% = 255
    IF RND > .5 THEN b% = 255
  END IF

  OUT &H3C8, i%
  OUT &H3C9, r% * 63 \ 255
  OUT &H3C9, g% * 63 \ 255
  OUT &H3C9, b% * 63 \ 255
NEXT i%

DO
  FOR i% = 1 TO 6
    COLOR i%

    s$ = st$(i%)

    FOR j% = 1 TO LEN(s$) STEP 8
      x1% = x2%
      y1% = y2%

      x2% = VAL(MID$(s$, j%, 4))

      IF x2% = 9999 THEN
        first% = 1
      ELSE
        x2% = x2% * 5
        x2% = x2% + 80
        y2% = VAL(MID$(s$, j% + 4, 4))
        y2% = y2% * 5
        y2% = y2% + 30

        IF first% THEN
          first% = 0
        ELSE
          IF RND > .5 THEN LINE (x1%, y1%)-(x2%, y2%)
        END IF
      END IF
    NEXT j%
  NEXT i%
  st = TIMER: WHILE st = TIMER: WEND
LOOP WHILE INKEY$ = ""
